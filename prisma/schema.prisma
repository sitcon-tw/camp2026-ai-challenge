generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Team {
  teamNumber        String   @id
  /// JSON: RoleId[]
  roles             String   @default("[\"newbie\"]")
  /// JSON: number[]
  completedLevels   String   @default("[]")
  clawbotActivated  Boolean  @default(false)
  lockkeeperActivated Boolean @default(false)
  /// backend-suggested LockKeeper draft the player edits & sends
  /// (MySQL disallows a DEFAULT on LONGTEXT; set explicitly on create — see initTeam)
  lockkeeperDraft   String   @db.LongText
  /// JSON: Record<string, string>
  /// (MySQL disallows a DEFAULT on LONGTEXT; set explicitly on create — see initTeam)
  difyConversations String   @db.LongText
  createdAt         DateTime @default(now())

  channelMessages ChannelMessage[]
  aiLogs          AiLog[]
}

model ChannelMessage {
  id         String   @id
  teamNumber String
  channelId  String
  author     String
  content    String   @db.LongText
  isBot      Boolean  @default(false)
  /// "clawbot-link" etc. — null for normal messages
  special    String?
  createdAt  DateTime @default(now())

  team Team @relation(fields: [teamNumber], references: [teamNumber])

  @@index([teamNumber, channelId])
}

model AiLog {
  id          Int      @id @default(autoincrement())
  teamNumber  String
  agent       String
  userMessage String   @db.LongText
  aiResponse  String   @db.LongText
  timestamp   DateTime @default(now())
  levelPassed Boolean  @default(false)

  team Team @relation(fields: [teamNumber], references: [teamNumber])

  @@index([teamNumber])
}
