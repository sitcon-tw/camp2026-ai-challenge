# Copy this file to .env.local (and .env for Prisma CLI) and fill in your values.

# SQLite database path (relative to prisma/schema.prisma)
DATABASE_URL="file:./dev.db"

# Dify AI backend — copy to .env.local and fill in your values.
# While a key is empty, that bot falls back to local placeholder logic.

# shared base url of your Dify instance (cloud: https://api.dify.ai/v1)
DIFY_API_URL=https://dify.nightfury.tw/v1

# one API key per Dify app / workflow
DIFY_KEY_AI_GUARD=             # Level 1 — gate screen
DIFY_KEY_UPGRADE_BOT=          # Level 2 — #get-role channel
DIFY_KEY_CLAWBOT=              # Level 3 — Clawbot DM
DIFY_KEY_LOCKKEEPER=           # Level 4 — operator (member_07) the player engineers
DIFY_KEY_LOCKKEEPER_DRAFT=     # Level 4 (optional) — writes the LockKeeper draft the player edits

# Flag values shown to players after each level is cleared.
# Defaults to placeholder strings when unset — set real flags before the event.
FLAG_1=
FLAG_2=
FLAG_3=
FLAG_4=
